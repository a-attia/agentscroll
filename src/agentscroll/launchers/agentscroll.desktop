[Desktop Entry]
Type=Application
Name=agentscroll
Comment=Browse your AI coding-agent sessions
Exec=agentscroll web
Terminal=false
Categories=Development;Utility;
# Install: copy to ~/.local/share/applications/ (and `chmod +x` if needed),
# or run `xdg-desktop-menu install agentscroll.desktop`. Then launch from your
# application menu like any other app.
